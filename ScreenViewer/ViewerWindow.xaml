<Window x:Class="ScreenViewer.ViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Antigravity Screen Viewer"
        Width="440" Height="920"
        WindowStartupLocation="CenterScreen"
        Background="#0a0a0f"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="#0e0e1a" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ANTIGRAVITY" FontSize="14" FontWeight="Bold" Foreground="#00ff88" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDeviceName" Text=" | No Device" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <TextBlock x:Name="TxtFps" Text="" FontSize="10" Foreground="#00ccff" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtIp" Width="130" Background="#12121f" Foreground="#e0e0e0" BorderBrush="#333" Padding="4,3" FontSize="11" Text="127.0.0.1"/>
                    <TextBlock Text=":" Foreground="#666" VerticalAlignment="Center" Margin="2,0"/>
                    <TextBox x:Name="TxtPort" Width="45" Background="#12121f" Foreground="#e0e0e0" BorderBrush="#333" Padding="4,3" FontSize="11" Text="8888"/>
                    <Button x:Name="BtnConnect" Content="Connect" Margin="5,0,0,0" Padding="10,4" FontSize="11"
                            Background="#1a1a2e" Foreground="#00ff88" BorderBrush="#00ff88" Click="BtnConnect_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- PHONE SCREEN (Interactive - click through) -->
        <Border Grid.Row="1" Background="#000000" Margin="10,5,10,5" CornerRadius="20" ClipToBounds="True"
                BorderBrush="#222" BorderThickness="2">
            <Grid>
                <Image x:Name="ImgScreen" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"
                       MouseLeftButtonDown="ImgScreen_MouseDown" MouseMove="ImgScreen_MouseMove" MouseLeftButtonUp="ImgScreen_MouseUp"/>
                <!-- Overlay for touch indicator -->
                <Canvas x:Name="TouchOverlay" IsHitTestVisible="False">
                    <Ellipse x:Name="TouchDot" Width="30" Height="30" Fill="#4400ff88" Stroke="#00ff88" StrokeThickness="2" Visibility="Collapsed"/>
                </Canvas>
                <!-- No connection overlay -->
                <StackPanel x:Name="OverlayNoConnection" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="No Device Connected" FontSize="18" Foreground="#444" HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter IP and click Connect" FontSize="12" Foreground="#333" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- NAVIGATION BAR (Back, Home, Recents) -->
        <Border Grid.Row="2" Background="#0e0e1a" Padding="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Back" Width="80" Padding="5" Margin="5" Background="#1a1a2e" Foreground="#aaa" BorderBrush="#333" FontSize="11" Click="BtnBack_Click"/>
                <Button Content="Home" Width="80" Padding="5" Margin="5" Background="#1a1a2e" Foreground="#aaa" BorderBrush="#333" FontSize="11" Click="BtnHome_Click"/>
                <Button Content="Recents" Width="80" Padding="5" Margin="5" Background="#1a1a2e" Foreground="#aaa" BorderBrush="#333" FontSize="11" Click="BtnRecents_Click"/>
                <Button Content="Screenshot" Width="80" Padding="5" Margin="5" Background="#1a1a2e" Foreground="#00ccff" BorderBrush="#333" FontSize="11" Click="BtnScreenshot_Click"/>
            </StackPanel>
        </Border>

        <!-- INPUT BAR -->
        <Border Grid.Row="3" Background="#0e0e1a" Padding="8,5">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TxtInput" Width="280" Background="#12121f" Foreground="#e0e0e0" BorderBrush="#333" Padding="6,4" FontSize="12"
                         KeyDown="TxtInput_KeyDown"/>
                <Button Content="Type" Padding="10,4" Margin="5,0,0,0" Background="#1a1a2e" Foreground="#00ff88" BorderBrush="#00ff88" FontSize="11" Click="BtnType_Click"/>
                <Button Content="Enter" Padding="10,4" Margin="5,0,0,0" Background="#1a1a2e" Foreground="#ffcc00" BorderBrush="#333" FontSize="11" Click="BtnEnter_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
