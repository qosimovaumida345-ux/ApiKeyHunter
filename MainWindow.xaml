<Window x:Class="AntigravityMobile.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Antigravity Mobile Controller v2026"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#0a0a0f"
        Foreground="White">
    <Window.Resources>
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#00ff88"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#00ff88"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00ff88"/>
                                <Setter Property="Foreground" Value="#0a0a0f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkTxt" TargetType="TextBox">
            <Setter Property="Background" Value="#12121f"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#00ff88"/>
        </Style>
        <Style x:Key="HeaderLbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00ff88"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="#0e0e1a" BorderBrush="#1a1a2e" BorderThickness="0,0,2,0">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="ANTIGRAVITY" FontSize="20" FontWeight="Bold" Foreground="#00ff88" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Mobile Control" FontSize="12" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button x:Name="BtnTabDevice" Content="Device Manager" Style="{StaticResource DarkBtn}" Click="BtnTabDevice_Click"/>
                <Button x:Name="BtnTabGoogle" Content="Google Factory" Style="{StaticResource DarkBtn}" Click="BtnTabGoogle_Click"/>
                <Button x:Name="BtnTabApiKeys" Content="API Key Scraper" Style="{StaticResource DarkBtn}" Click="BtnTabApiKeys_Click"/>
                <Button x:Name="BtnTabAccounts" Content="Saved Accounts" Style="{StaticResource DarkBtn}" Click="BtnTabAccounts_Click"/>
                <Button x:Name="BtnTabLogs" Content="Live Logs" Style="{StaticResource DarkBtn}" Click="BtnTabLogs_Click"/>

                <TextBlock x:Name="TxtServerStatus" Text="Server: Stopped" FontSize="11" Foreground="#ff4444" Margin="10,30,0,0"/>
                <TextBlock x:Name="TxtDeviceCount" Text="Devices: 0" FontSize="11" Foreground="#888" Margin="10,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Column="1" Margin="20">
            <!-- DEVICE MANAGER TAB -->
            <StackPanel x:Name="PanelDevice" Visibility="Visible">
                <TextBlock Text="Device Manager" Style="{StaticResource HeaderLbl}"/>
                <TextBlock Text="Telefoningizni ulab, pastdagi tugmani bosing. Telefon bilan PC bir Wi-Fi tarmoqda bo'lishi kerak." Foreground="#aaa" Margin="0,0,0,15" TextWrapping="Wrap"/>
                
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnStartServer" Content="Start Server" Style="{StaticResource DarkBtn}" Click="BtnStartServer_Click"/>
                    <Button x:Name="BtnStopServer" Content="Stop Server" Style="{StaticResource DarkBtn}" Click="BtnStopServer_Click" IsEnabled="False"/>
                </StackPanel>

                <TextBlock Text="Server Port:" Foreground="#aaa" Margin="4,15,0,3"/>
                <TextBox x:Name="TxtPort" Text="8888" Style="{StaticResource DarkTxt}" Width="120" HorizontalAlignment="Left"/>
                
                <TextBlock Text="Connected Devices:" FontSize="16" FontWeight="Bold" Foreground="#00ccff" Margin="0,20,0,5"/>
                <ListBox x:Name="LstDevices" Background="#12121f" Foreground="White" BorderBrush="#333" Height="150" Margin="0,0,0,10"/>

                <TextBlock Text="Phone Screen Preview:" FontSize="16" FontWeight="Bold" Foreground="#00ccff" Margin="0,10,0,5"/>
                <Border Background="#000" BorderBrush="#333" BorderThickness="1" Width="360" Height="640" HorizontalAlignment="Left" CornerRadius="12">
                    <Image x:Name="ImgPhoneScreen" Stretch="Uniform"/>
                </Border>
            </StackPanel>

            <!-- GOOGLE FACTORY TAB -->
            <StackPanel x:Name="PanelGoogle" Visibility="Collapsed">
                <TextBlock Text="Google Account Factory" Style="{StaticResource HeaderLbl}"/>
                <TextBlock Text="Telefon orqali avtomatik Google account yaratish. Har bir account uchun email va parol 'data' papkasiga saqlanadi." Foreground="#aaa" Margin="0,0,0,15" TextWrapping="Wrap"/>

                <TextBlock Text="Device:" Foreground="#aaa" Margin="4,0,0,3"/>
                <ComboBox x:Name="CmbDeviceGoogle" Background="#12121f" Foreground="White" Width="250" HorizontalAlignment="Left" Margin="4"/>

                <TextBlock Text="Nechta Account yaratish:" Foreground="#aaa" Margin="4,10,0,3"/>
                <TextBox x:Name="TxtAccountCount" Text="5" Style="{StaticResource DarkTxt}" Width="120" HorizontalAlignment="Left"/>

                <TextBlock Text="Parol (barcha accountlar uchun):" Foreground="#aaa" Margin="4,10,0,3"/>
                <TextBox x:Name="TxtGooglePassword" Text="Antig@2026!" Style="{StaticResource DarkTxt}" Width="250" HorizontalAlignment="Left"/>

                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <Button x:Name="BtnStartGoogleFactory" Content="Start Creating" Style="{StaticResource DarkBtn}" Click="BtnStartGoogleFactory_Click"/>
                    <Button x:Name="BtnStopGoogleFactory" Content="Stop" Style="{StaticResource DarkBtn}" Click="BtnStopGoogleFactory_Click" IsEnabled="False"/>
                </StackPanel>

                <TextBlock x:Name="TxtGoogleProgress" Text="Status: Idle" Foreground="#ffcc00" FontSize="14" Margin="4,15,0,0"/>
            </StackPanel>

            <!-- API KEY SCRAPER TAB -->
            <StackPanel x:Name="PanelApiKeys" Visibility="Collapsed">
                <TextBlock Text="API Key Scraper" Style="{StaticResource HeaderLbl}"/>
                <TextBlock Text="Yaratilgan Google accountlar bilan Gemini, Groq, Mistral, HuggingFace API key olish." Foreground="#aaa" Margin="0,0,0,15" TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="ChkGemini" Content="Gemini API" Foreground="#00ff88" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <CheckBox x:Name="ChkGroq" Content="Groq API" Foreground="#00ccff" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <CheckBox x:Name="ChkMistral" Content="Mistral API" Foreground="#ff8800" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <CheckBox x:Name="ChkHuggingFace" Content="HuggingFace" Foreground="#ffcc00" IsChecked="True" VerticalAlignment="Center"/>
                </StackPanel>

                <Button x:Name="BtnStartScrape" Content="Start Scraping API Keys" Style="{StaticResource DarkBtn}" Click="BtnStartScrape_Click" HorizontalAlignment="Left"/>

                <TextBlock x:Name="TxtApiProgress" Text="Status: Idle" Foreground="#ffcc00" FontSize="14" Margin="4,15,0,0"/>
                
                <TextBlock Text="Saved API Keys:" FontSize="16" FontWeight="Bold" Foreground="#00ccff" Margin="0,20,0,5"/>
                <ListBox x:Name="LstApiKeys" Background="#12121f" Foreground="#00ff88" BorderBrush="#333" Height="300" Margin="0,0,0,10" FontFamily="Consolas"/>
            </StackPanel>

            <!-- SAVED ACCOUNTS TAB -->
            <StackPanel x:Name="PanelAccounts" Visibility="Collapsed">
                <TextBlock Text="Saved Google Accounts" Style="{StaticResource HeaderLbl}"/>
                <TextBlock Text="Barcha yaratilgan Google accountlar va ularning API keylari." Foreground="#aaa" Margin="0,0,0,15" TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Refresh" Style="{StaticResource DarkBtn}" Click="BtnRefreshAccounts_Click"/>
                    <Button Content="Export to JSON" Style="{StaticResource DarkBtn}" Click="BtnExportAccounts_Click"/>
                </StackPanel>

                <DataGrid x:Name="GridAccounts" Background="#12121f" Foreground="White" 
                          BorderBrush="#333" AutoGenerateColumns="True" IsReadOnly="True"
                          Height="400" RowBackground="#0e0e1a" AlternatingRowBackground="#12121f"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#222"/>
            </StackPanel>

            <!-- LOGS TAB -->
            <StackPanel x:Name="PanelLogs" Visibility="Collapsed">
                <TextBlock Text="Live Logs" Style="{StaticResource HeaderLbl}"/>
                <Button Content="Clear Logs" Style="{StaticResource DarkBtn}" Click="BtnClearLogs_Click" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                <TextBox x:Name="TxtLogs" Background="#050510" Foreground="#00ff88" FontFamily="Consolas" FontSize="12"
                         IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="550"
                         BorderBrush="#222" Padding="10"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
